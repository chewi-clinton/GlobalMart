DB_PASSWORD=globalmart_secret

# ─── RabbitMQ ─────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://globalmart:globalmart_secret@rabbitmq:5672/

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Service ──────────────────────────────────────────────────────────
