# ─── Django ───────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production-abc123xyz
DEBUG=True

# ─── Database ─────────────────────────────────────────────────────────
DB_NAME=users_db
DB_HOST=postgres
DB_PORT=5432
